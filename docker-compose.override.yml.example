
version: '3.8'

services:
  ollama:
    image: ollama/ollama:latest
    container_name: ollama-mistral
    ports:
      - "11434:11434"
    volumes:
      - ollama_data:/root/.ollama
    environment:
      - OLLAMA_HOST=0.0.0.0
    restart: unless-stopped
    command: >
      sh -c "ollama serve &
      sleep 10 &&
      ollama pull mistral &&
      wait"
  log-analyzer:
    build: .
    ports:
      - "8000:8000"
    environment:
      - PORT=8000
    volumes:
      - .:/app
    depends_on:
      - ollama
volumes:
  ollama_data: